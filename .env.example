DATABASE_URL="postgresql://rushbite:rushbite_dev@localhost:5433/rushbite?schema=public"
# Local-development placeholder. Production must set a unique non-default value.
ADMIN_PASSWORD="change-me-in-prod"
# Used only by `npm run auth:bootstrap-owner`.
ADMIN_BOOTSTRAP_EMAIL="owner@example.com"
ADMIN_BOOTSTRAP_NAME="Owner"
ADMIN_BOOTSTRAP_PASSWORD=""
# Comma-separated admin origins accepted for state-changing admin requests.
# Set this in production to the public admin URL, e.g. "https://kiosk.example.com".
# If unset, local development falls back to the request origin.
ADMIN_ALLOWED_ORIGINS="http://localhost:3000,http://127.0.0.1:3000"
# Secret used to hash login rate-limit subjects and IPs before storing attempts.
LOGIN_RATE_LIMIT_SECRET=""
# Rate-limit defaults are production-safe starting points and can be tuned after
# observing real traffic. Progressive backoff starts after the configured number
# of failures and uses the comma-separated seconds below.
LOGIN_PROGRESSIVE_BACKOFF_MIN_FAILURES="3"
LOGIN_PROGRESSIVE_BACKOFF_SECONDS="1,5,60,300,1800"
ADMIN_LOGIN_RATE_LIMIT_ACCOUNT_WINDOW_SECONDS="900"
ADMIN_LOGIN_RATE_LIMIT_ACCOUNT_MAX="10"
ADMIN_LOGIN_RATE_LIMIT_IP_WINDOW_SECONDS="60"
ADMIN_LOGIN_RATE_LIMIT_IP_MAX="20"
ADMIN_MFA_RATE_LIMIT_ACCOUNT_WINDOW_SECONDS="900"
ADMIN_MFA_RATE_LIMIT_ACCOUNT_MAX="10"
ADMIN_MFA_RATE_LIMIT_IP_WINDOW_SECONDS="300"
ADMIN_MFA_RATE_LIMIT_IP_MAX="30"
ADMIN_STEP_UP_RATE_LIMIT_ACCOUNT_WINDOW_SECONDS="900"
ADMIN_STEP_UP_RATE_LIMIT_ACCOUNT_MAX="10"
ADMIN_STEP_UP_RATE_LIMIT_IP_WINDOW_SECONDS="300"
ADMIN_STEP_UP_RATE_LIMIT_IP_MAX="30"
ADMIN_PASSWORD_RESET_RATE_LIMIT_ACCOUNT_WINDOW_SECONDS="900"
ADMIN_PASSWORD_RESET_RATE_LIMIT_ACCOUNT_MAX="5"
ADMIN_PASSWORD_RESET_RATE_LIMIT_IP_WINDOW_SECONDS="60"
ADMIN_PASSWORD_RESET_RATE_LIMIT_IP_MAX="20"
DEVICE_LOGIN_RATE_LIMIT_ACCOUNT_WINDOW_SECONDS="900"
DEVICE_LOGIN_RATE_LIMIT_ACCOUNT_MAX="10"
DEVICE_LOGIN_RATE_LIMIT_IP_WINDOW_SECONDS="60"
DEVICE_LOGIN_RATE_LIMIT_IP_MAX="20"
# Secret used to encrypt Owner/Admin TOTP secrets and key recovery-code hashes.
ADMIN_MFA_SECRET_ENCRYPTION_KEY=""
# Secret used for Owner cooling-off cancel-token hashes and encrypted cancel links.
OWNER_CHANGE_CANCEL_TOKEN_SECRET=""
# Secret used for admin forgot-password reset-token hashes and encrypted reset links.
ADMIN_PASSWORD_RESET_TOKEN_SECRET=""
# Public HTTPS admin URL used in security email links.
ADMIN_PUBLIC_BASE_URL="http://localhost:3000"
# Auth/security email outbox sender. Local development can leave provider keys
# empty and use dry-run. Production should set RESEND_API_KEY and EMAIL_FROM,
# and should not enable AUTH_EMAIL_DRY_RUN except for explicit deployment tests.
RESEND_API_KEY=""
EMAIL_FROM=""
EMAIL_REPLY_TO=""
AUTH_EMAIL_DRY_RUN="true"
# Development worker guard. Leave false unless intentionally testing dry-run
# worker behavior, because dry-run marks rows SENT without provider delivery.
AUTH_EMAIL_WORKER_ALLOW_DRY_RUN="false"
AUTH_EMAIL_WORKER_INTERVAL_MS="10000"
# Optional emergency compatibility flag. Leave unset in production unless a
# short, explicit legacy-device cutover window is approved.
ALLOW_LEGACY_DEVICE_AUTH=""
# Deal base strict customer enforcement. Leave false until `npm run
# audit:deal-links -- --suggest` reports no unresolved repair issues, or every
# remaining repair issue is intentionally hidden from customers.
STRICT_DEAL_BASE_ENFORCEMENT="false"
NEXT_PUBLIC_STORE_NAME="Vicky's"
NEXT_PUBLIC_STORE_LOCATION="Sherwood Park, AB"
NEXT_PUBLIC_KIOSK_ID="01"
NEXT_PUBLIC_SERVICE_MODEL="PICKUP_ONLY"
NEXT_PUBLIC_PAYMENT_MODE="MOCK"
NEXT_PUBLIC_SUPPORTED_LANGUAGES="en"
NEXT_PUBLIC_PREP_MINUTES="6"
NEXT_PUBLIC_ORDER_RESET_SECONDS="20"
# Legacy shared device-key fallback. Local development enables this by default.
# Production should leave ALLOW_LEGACY_DEVICE_AUTH unset and use /admin/devices
# to enroll per-device access codes instead.
KIOSK_DEVICE_KEY="change-me-kiosk"
KITCHEN_DEVICE_KEY="change-me-kitchen"
BOARD_DEVICE_KEY="change-me-board"
COUNTER_DEVICE_KEY="change-me-counter"
STRIPE_SECRET_KEY=""
STRIPE_TERMINAL_READER_ID=""
STRIPE_TERMINAL_CURRENCY="cad"
GST_RATE="0.05"
NEXT_PUBLIC_PAYMENT_METHODS="CARD,MOBILE,CASH"
# -----------------------------------------------------------------------------
# Product imagery storage
# -----------------------------------------------------------------------------
# Driver selector. "local" (default) writes to the Pi's disk; "s3" writes to
# an S3-compatible bucket (AWS S3, Cloudflare R2, MinIO). Leave unset on a
# single-Pi deployment; set to "s3" for cloud topologies.
IMAGE_STORAGE_DRIVER=""

# --- Default (local disk) driver ---------------------------------------------
# Absolute path to the directory that holds uploaded images. Default:
# <cwd>/var/uploads. In production on a Pi, point this at durable storage
# outside the app tree, e.g. /var/lib/rushbite/uploads — that way app
# redeploys (overwrite /opt/rushbite) don't wipe operator uploads.
# Relative paths are rejected with a clear 503.
IMAGE_LOCAL_UPLOAD_DIR=""

# --- Opt-in (S3 / R2) driver — required only when IMAGE_STORAGE_DRIVER="s3" ---
IMAGE_BUCKET_ENDPOINT=""
IMAGE_BUCKET_REGION="auto"
IMAGE_BUCKET_NAME=""
IMAGE_BUCKET_ACCESS_KEY_ID=""
IMAGE_BUCKET_SECRET_ACCESS_KEY=""
# Public CDN base URL in front of the bucket's live prefix.
# Example: "https://images.yourdomain.com" (no trailing slash required).
NEXT_PUBLIC_IMAGE_CDN_BASE=""

# --- Shared ------------------------------------------------------------------
# Optional comma-separated extra hosts accepted by the admin "paste URL"
# escape hatch. Unset/empty disables paste-URL entirely; only server-produced
# imageUrl values (local /uploads/... or managed CDN URL) are accepted.
IMAGE_PASTE_URL_ALLOWLIST=""
